# 复制此文件为 .env.local，再填写真实值。不要把 .env.local 提交到 GitHub。
OPENAI_API_KEY=

# API 备用分析模型。可按账户权限修改。
OPENAI_MODEL=gpt-5.4-mini

# 本机 Codex 分析最长等待时间（毫秒）。超时后自动改用 API。
CODEX_TIMEOUT_MS=120000

# API 分析最长等待时间（毫秒）。
OPENAI_TIMEOUT_MS=120000

# DeepSeek作为低成本备用分析通道。
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=120000
# 默认顺序：本机Codex → DeepSeek → OpenAI → 排队。
ANALYSIS_PROVIDER_ORDER=codex,deepseek,openai

# 可选：配置后将结构化数据同步到 GitHub Gist；留空则仅保存本地 SQLite。
# Token 需要 gist 写入权限，只能放在 .env.local 或系统环境变量中。
GITHUB_GIST_TOKEN=
# 已有 Gist 时填写；留空会在首次同步时新建 Secret Gist，并把ID保存到 data/gist-id.txt。
GITHUB_GIST_ID=
